# HARE Streamlit thesis-demo environment
#
# Copy this file to `.env` for local development.
# Keep `.env` private and never commit real secrets.

# ---------------------------------------------------------------------------
# App security
# ---------------------------------------------------------------------------
# Used for app-level secret material. Set a long random value in deployment.
APP_SECRET_KEY=change-me-to-a-long-random-secret

# First researcher account bootstrap.
# On startup, if this email does not exist, the app creates an active researcher.
ADMIN_BOOTSTRAP_EMAIL=researcher@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisPassword123

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------
# Azure PostgreSQL connection string.
# Leave blank for the local SQLite fallback under ./data/hare_demo.sqlite3.
DATABASE_URL=
# Example:
# DATABASE_URL=postgresql://hare_user:strong_password@hare-db.postgres.database.azure.com:5432/hare?sslmode=require

# ---------------------------------------------------------------------------
# Azure Blob Storage
# ---------------------------------------------------------------------------
# Used for uploaded patient image storage and model download.
# Leave blank for local image fallback under ./data/uploads.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_IMAGE_CONTAINER=hare-images

# Existing model downloader uses this fixed container name for model weights:
# hare-models

# ---------------------------------------------------------------------------
# Model runtime
# ---------------------------------------------------------------------------
MODEL_DIR=./models
ACTIVE_CHECKPOINT=stage2_best.pth
GA_THETA=0.1372
GA_TAU=1.8162
GA_ALPHA=0.0582
