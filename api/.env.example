# API-local environment template
# Use this if you run uvicorn from inside the api/ folder.

# API
DEBUG=true
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Model settings
# If running from api/ folder, models are in ../models
MODEL_DIR=../models
ACTIVE_CHECKPOINT=stage2_v8.pth

# GA defaults
GA_THETA=0.3985
GA_TAU=0.7671
GA_ALPHA=0.5467

# Optional cloud storage
BLOB_CONNECTION_STRING=
